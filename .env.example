# ---------- API ----------
NODE_ENV=development
API_PORT=3333
JWT_SECRET=troque-este-segredo

# ---------- Postgres ----------
DATABASE_URL=postgresql://zapye:zapye@localhost:5432/zapye?schema=public
POSTGRES_USER=zapye
POSTGRES_PASSWORD=zapye
POSTGRES_DB=zapye

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- Evolution API ----------
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=changeme
# token que validamos no header dos webhooks recebidos
EVOLUTION_WEBHOOK_TOKEN=changeme

# ---------- IA ----------
# AI_PROVIDER = openai | anthropic
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ---------- Web ----------
NEXT_PUBLIC_API_URL=http://localhost:3333
